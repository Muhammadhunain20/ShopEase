@model IEnumerable<ShopEase.Models.Order>
@{
    ViewData["Title"] = "Orders";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold"><i class="bi bi-receipt me-2 text-primary"></i>Orders</h2>
        <div class="d-flex gap-2">
            <a href="/Admin/Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>Dashboard</a>
            <a href="/Admin/Logout" class="btn btn-outline-danger"><i class="bi bi-box-arrow-right me-1"></i>Logout</a>
        </div>
    </div>

    <!-- Filter Tabs -->
    <div class="d-flex gap-2 mb-4 flex-wrap">
        @foreach (var s in new[] { "", "Pending", "Processing", "Shipped", "Delivered", "Cancelled" })
        {
            <a href="/Admin/Orders@(string.IsNullOrEmpty(s) ? "" : "?status=" + s)"
               class="btn btn-sm @(ViewBag.StatusFilter == (string.IsNullOrEmpty(s) ? null : s) || (string.IsNullOrEmpty(s) && ViewBag.StatusFilter == null) ? "btn-primary" : "btn-outline-secondary")">
                @(string.IsNullOrEmpty(s) ? "All" : s)
            </a>
        }
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Order #</th>
                            <th>Customer</th>
                            <th>City</th>
                            <th>Total</th>
                            <th>Payment</th>
                            <th>Status</th>
                            <th>Date</th>
                            <th>Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var order in Model)
                        {
                            var badgeClass = order.Status switch {
                                "Pending" => "bg-warning text-dark",
                                "Processing" => "bg-info",
                                "Shipped" => "bg-primary",
                                "Delivered" => "bg-success",
                                "Cancelled" => "bg-danger",
                                _ => "bg-secondary"
                            };
                            <tr>
                                <td><strong>#@order.Id</strong></td>
                                <td>
                                    <div class="fw-semibold">@order.CustomerName</div>
                                    <small class="text-muted">@order.Email</small>
                                </td>
                                <td>@order.City</td>
                                <td class="fw-semibold">PKR @order.TotalAmount.ToString("N0")</td>
                                <td><span class="badge bg-secondary">@order.PaymentMethod</span></td>
                                <td><span class="badge @badgeClass">@order.Status</span></td>
                                <td><small class="text-muted">@order.OrderDate.ToString("MMM dd, yyyy")</small></td>
                                <td>
                                    <a href="/Admin/OrderDetail/@order.Id" class="btn btn-sm btn-outline-primary">
                                        <i class="bi bi-eye me-1"></i>View
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            @if (!Model.Any())
            {
                <p class="text-center text-muted py-4">No orders found.</p>
            }
        </div>
    </div>
</div>
