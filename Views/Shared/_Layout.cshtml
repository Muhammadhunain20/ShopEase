<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ShopEase</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>

    <!-- Top Bar -->
    <div class="top-bar bg-dark text-white py-1 d-none d-md-block">
        <div class="container d-flex justify-content-between align-items-center">
            <small><i class="bi bi-truck me-1"></i> Free shipping on orders over PKR 3,000</small>
            <small><i class="bi bi-telephone me-1"></i> 0300-1234567</small>
        </div>
    </div>

    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg navbar-light bg-white shadow-sm">
        <div class="container">
            <a class="navbar-brand fw-bold fs-3" href="/" style="color: var(--primary);">
                <i class="bi bi-bag-heart-fill me-1"></i>ShopEase
            </a>

            <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarMain">
                <!-- Search Bar -->
                <form class="d-flex mx-auto my-2 my-lg-0" style="width: 40%" action="/Product/Index" method="get">
                    <div class="input-group">
                        <input class="form-control border-end-0" type="search" name="search"
                               placeholder="Search products..." value="@ViewBag.SearchQuery" />
                        <button class="btn btn-outline-secondary border-start-0" type="submit">
                            <i class="bi bi-search"></i>
                        </button>
                    </div>
                </form>

                <ul class="navbar-nav ms-auto align-items-center gap-1">
                    <li class="nav-item">
                        <a class="nav-link" href="/Product/Index"><i class="bi bi-grid me-1"></i>Shop</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/Admin/Index"><i class="bi bi-gear me-1"></i>Admin</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link position-relative cart-icon-btn" href="/Cart/Index">
                            <i class="bi bi-cart3 fs-5"></i>
                            <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger cart-count" id="cartCount">
                                @(ViewBag.CartCount ?? 0)
                            </span>
                        </a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <!-- Main Content -->
    <main>
        @RenderBody()
    </main>

    <!-- Footer -->
    <footer class="bg-light text-white mt-5 pt-5 pb-3">
        <div class="container">
            <div class="row g-4">
                <div class="col-md-4">
                    <h5 class="fw-bold mb-3 text-black"><i class="bi bi-bag-heart-fill me-2" style="color:var(--primary)"></i>ShopEase</h5>
                    <p class="text-muted small">Your one-stop destination for quality products at great prices. Shop with confidence.</p>
                    <div class="d-flex gap-3 mt-3">
                        <a href="#" class="text-muted fs-5"><i class="bi bi-facebook"></i></a>
                        <a href="#" class="text-muted fs-5"><i class="bi bi-instagram"></i></a>
                        <a href="#" class="text-muted fs-5"><i class="bi bi-twitter-x"></i></a>
                    </div>
                </div>
                <div class="col-md-2">
                    <h6 class="fw-semibold mb-3 text-black">Quick Links</h6>
                    <ul class="list-unstyled small text-muted">
                        <li class="mb-1"><a href="/" class="text-muted text-decoration-none">Home</a></li>
                        <li class="mb-1"><a href="/Product/Index" class="text-muted text-decoration-none">Shop</a></li>
                        <li class="mb-1"><a href="/Cart/Index" class="text-muted text-decoration-none">Cart</a></li>
                    </ul>
                </div>
                <div class="col-md-3">
                    <h6 class="fw-semibold mb-3 text-black">Customer Service</h6>
                    <ul class="list-unstyled small text-muted">
                        <li class="mb-1"><i class="bi bi-telephone me-1"></i> 0300-1234567</li>
                        <li class="mb-1"><i class="bi bi-envelope me-1"></i> support@shopease.pk</li>
                        <li class="mb-1"><i class="bi bi-clock me-1"></i> Mon-Sat 9am-6pm</li>
                    </ul>
                </div>
                <div class="col-md-3">
                    <h6 class="fw-semibold mb-3 text-black">We Accept</h6>
                    <div class="d-flex gap-2 flex-wrap">
                        <span class="badge bg-secondary px-3 py-2"><i class="bi bi-cash me-1"></i>COD</span>
                        <span class="badge bg-secondary px-3 py-2"><i class="bi bi-credit-card me-1"></i>Card</span>
                        <span class="badge bg-secondary px-3 py-2">EasyPaisa</span>
                        <span class="badge bg-secondary px-3 py-2">JazzCash</span>
                    </div>
                </div>
            </div>
            <hr class="border-secondary mt-4" />
            <p class="text-center text-muted small mb-0">&copy; 2025 ShopEase. All rights reserved.</p>
        </div>
    </footer>

    <!-- Toast Notification -->
    <div class="position-fixed bottom-0 end-0 p-3" style="z-index: 11">
        <div id="cartToast" class="toast align-items-center text-bg-success border-0" role="alert">
            <div class="d-flex">
                <div class="toast-body" id="toastMessage">Item added to cart!</div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
